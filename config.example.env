WORKER_URL=https://smtp2worker.your-subdomain.workers.dev
BRIDGE_TOKEN=change-me-to-a-long-random-secret

# 默认监听本机，给同机应用配置 SMTP host=127.0.0.1 port=2525 即可。
SMTP_LISTEN_HOST=127.0.0.1
SMTP_LISTEN_PORT=2525

# 如果需要让应用使用 SMTP AUTH，就同时设置这两个值。
SMTP_USERNAME=smtp-user
SMTP_PASSWORD=smtp-password

# 可选 TLS。设置证书后支持 STARTTLS；IMPLICIT_TLS=true 时为 SMTPS。
# TLS_CERT_FILE=cert.pem
# TLS_KEY_FILE=key.pem
# REQUIRE_STARTTLS=false
# IMPLICIT_TLS=false
