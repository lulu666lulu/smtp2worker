name = "smtp2worker"
main = "src/worker.js"
compatibility_date = "2026-05-03"

[vars]
# Fallback only. By default the Worker uses the SMTP From address.
FROM_EMAIL = "Verification Code <noreply@example.com>"
# Set true if your SMTP client cannot send a Cloudflare Email Routing sender address.
# FORCE_FROM_EMAIL = "true"
DEFAULT_SUBJECT = "验证码"
# Optional: only allow recipients from these domains. Leave unset to rely on Cloudflare Email Routing verification.
# ALLOWED_RECIPIENT_DOMAINS = "example.com,example.org"
# DRY_RUN = "true"

[[send_email]]
name = "SEND_EMAIL"
# Optional Cloudflare-side restrictions:
# destination_address = "user@example.com"
# allowed_destination_addresses = [ "user@example.com", "user2@example.com" ]
# allowed_sender_addresses = [ "noreply@example.com" ]

# Set with wrangler secret put:
# BRIDGE_TOKEN
